{
  BasedOnStyle: LLVM,
  UseTab: Never,
  IndentWidth: 2,
  TabWidth: 2,
  BreakBeforeBraces: Attach,
  AllowShortBlocksOnASingleLine: false,
  AllowShortIfStatementsOnASingleLine: true,
  IndentCaseLabels: true,
  ColumnLimit: 80,
  AccessModifierOffset: -2,
  NamespaceIndentation: All,
  //IndentPPDirectives: AfterHash,
}
